<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_primary">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@color/bg_surface" android:orientation="horizontal"
            android:padding="16dp" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Dashboard Annuale" android:textColor="@color/text_primary"
                android:textSize="22sp" android:textStyle="bold"/>
            <Spinner android:id="@+id/spinnerYearAnnual" android:layout_width="wrap_content" android:layout_height="40dp"
                android:background="@drawable/bg_spinner" android:popupBackground="@color/bg_surface"/>
        </LinearLayout>

        <!-- KPI totali anno -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:padding="12dp">
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_margin="4dp"
                app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="14dp" app:cardElevation="4dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:text="Totale Entrate" android:textColor="@color/text_secondary"
                        android:textSize="10sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvTotaleEntrate" android:text="0 €"
                        android:textColor="@color/color_income" android:textSize="17sp" android:textStyle="bold"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <View android:layout_width="match_parent" android:layout_height="2dp"
                        android:background="@color/color_income" android:alpha="0.4" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_margin="4dp"
                app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="14dp" app:cardElevation="4dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:text="Totale Spese" android:textColor="@color/text_secondary"
                        android:textSize="10sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvTotaleSpese" android:text="0 €"
                        android:textColor="@color/color_expense" android:textSize="17sp" android:textStyle="bold"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <View android:layout_width="match_parent" android:layout_height="2dp"
                        android:background="@color/color_expense" android:alpha="0.4" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- SEZIONE ENTRATE -->
        <TextView android:text="ENTRATE" android:textColor="@color/color_income"
            android:textSize="15sp" android:textStyle="bold"
            android:paddingHorizontal="16dp" android:paddingTop="12dp" android:paddingBottom="4dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <!-- Confronto Entrate/Spese per mese (grouped bar) -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp" android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="14dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="12dp">
                <TextView android:text="Entrate vs Spese per Mese" android:textColor="@color/text_secondary"
                    android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <com.github.mikephil.charting.charts.BarChart android:id="@+id/barChartConfronto"
                    android:layout_width="match_parent" android:layout_height="220dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Stats entrate -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingHorizontal="12dp" android:paddingBottom="8dp">
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_margin="4dp"
                app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:text="Media Mensile" android:textColor="@color/text_secondary"
                        android:textSize="9sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvMediaEntrate" android:text="0 €"
                        android:textColor="@color/color_income" android:textSize="14sp" android:textStyle="bold"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_margin="4dp"
                app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:text="Mese più alto" android:textColor="@color/text_secondary"
                        android:textSize="9sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvMaxEntrate" android:text="-"
                        android:textColor="@color/color_income" android:textSize="14sp" android:textStyle="bold"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_margin="4dp"
                app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:text="Mese più basso" android:textColor="@color/text_secondary"
                        android:textSize="9sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvMinEntrate" android:text="-"
                        android:textColor="@color/text_secondary" android:textSize="14sp" android:textStyle="bold"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Donut entrate per categoria -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp" android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="14dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="12dp">
                <TextView android:text="Ripartizione Reddito Annuo per Fonte" android:textColor="@color/text_secondary"
                    android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <com.github.mikephil.charting.charts.PieChart android:id="@+id/pieChartEntrate"
                    android:layout_width="match_parent" android:layout_height="200dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- SEZIONE SPESE -->
        <TextView android:text="SPESE" android:textColor="@color/color_expense"
            android:textSize="15sp" android:textStyle="bold"
            android:paddingHorizontal="16dp" android:paddingTop="12dp" android:paddingBottom="4dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <!-- Bar chart spese mensili -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp" android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="14dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="12dp">
                <TextView android:text="Spese per Mese" android:textColor="@color/text_secondary"
                    android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <com.github.mikephil.charting.charts.BarChart android:id="@+id/barChartSpeseMensili"
                    android:layout_width="match_parent" android:layout_height="200dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Need/Want/Abbonamenti annuali -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingHorizontal="12dp" android:paddingBottom="8dp">
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_margin="4dp"
                app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:text="Necessarie" android:textColor="@color/text_secondary"
                        android:textSize="9sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvNecessarie" android:text="0 €"
                        android:textColor="@color/color_need" android:textSize="14sp" android:textStyle="bold"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvPctNecessarie" android:text="0%"
                        android:textColor="@color/text_secondary" android:textSize="10sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_margin="4dp"
                app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:text="Volontarie" android:textColor="@color/text_secondary"
                        android:textSize="9sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvVolontarie" android:text="0 €"
                        android:textColor="@color/color_want" android:textSize="14sp" android:textStyle="bold"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvPctVolontarie" android:text="0%"
                        android:textColor="@color/text_secondary" android:textSize="10sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_margin="4dp"
                app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:text="Abbonamenti" android:textColor="@color/text_secondary"
                        android:textSize="9sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvAbbonamenti" android:text="0 €"
                        android:textColor="@color/color_expense" android:textSize="14sp" android:textStyle="bold"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Stats spese -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingHorizontal="12dp" android:paddingBottom="8dp">
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_margin="4dp"
                app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:text="Spese Mensili Medie" android:textColor="@color/text_secondary"
                        android:textSize="9sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvMediaSpese" android:text="0 €"
                        android:textColor="@color/color_expense" android:textSize="14sp" android:textStyle="bold"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_margin="4dp"
                app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:text="Mese più alto" android:textColor="@color/text_secondary"
                        android:textSize="9sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvMaxSpese" android:text="-"
                        android:textColor="@color/color_expense" android:textSize="14sp" android:textStyle="bold"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_margin="4dp"
                app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:text="Mese più basso" android:textColor="@color/text_secondary"
                        android:textSize="9sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvMinSpese" android:text="-"
                        android:textColor="@color/text_secondary" android:textSize="14sp" android:textStyle="bold"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Donut spese annuale -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp" android:layout_marginBottom="100dp"
            app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="14dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="12dp">
                <TextView android:text="Ripartizione Spese Annuali in %" android:textColor="@color/text_secondary"
                    android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <com.github.mikephil.charting.charts.PieChart android:id="@+id/pieChartSpese"
                    android:layout_width="match_parent" android:layout_height="220dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>



        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- SEZIONE: TREND PATRIMONIO NETTO                             -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView android:id="@+id/cardPatrimonio"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp" android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="14dp" app:cardElevation="3dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <!-- Header con KPI finali -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📈 Trend Patrimonio Netto"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" android:textStyle="bold"/>
                </LinearLayout>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Risparmi accumulati − Debiti accumulati mese per mese"
                    android:textColor="@color/text_secondary" android:textSize="11sp"
                    android:layout_marginBottom="12dp"/>

                <!-- 3 KPI cards: risparmi totali, debiti totali, patrimonio netto -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_margin="4dp"
                        app:cardBackgroundColor="#0D00E5A0" app:cardCornerRadius="10dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="10dp" android:gravity="center">
                            <TextView android:text="Risparmi" android:textColor="@color/text_secondary"
                                android:textSize="9sp"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:id="@+id/tvPatrimonioRisparmi"
                                android:text="0 €" android:textColor="@color/color_saving"
                                android:textSize="14sp" android:textStyle="bold"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                    <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_margin="4dp"
                        app:cardBackgroundColor="#0DFF4081" app:cardCornerRadius="10dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="10dp" android:gravity="center">
                            <TextView android:text="Debiti" android:textColor="@color/text_secondary"
                                android:textSize="9sp"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:id="@+id/tvPatrimonioDebiti"
                                android:text="0 €" android:textColor="@color/color_expense"
                                android:textSize="14sp" android:textStyle="bold"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                    <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_margin="4dp"
                        app:cardBackgroundColor="#0DFFD600" app:cardCornerRadius="10dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="10dp" android:gravity="center">
                            <TextView android:text="Netto" android:textColor="@color/text_secondary"
                                android:textSize="9sp"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:id="@+id/tvPatrimonioNetto"
                                android:text="0 €" android:textColor="#FFD600"
                                android:textSize="14sp" android:textStyle="bold"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Grafico a linea -->
                <com.github.mikephil.charting.charts.LineChart android:id="@+id/lineChartPatrimonio"
                    android:layout_width="match_parent" android:layout_height="220dp"/>

                <!-- Legenda -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center" android:layout_marginTop="8dp">
                    <View android:layout_width="12dp" android:layout_height="12dp"
                        android:background="#00E5A0" android:layout_marginEnd="4dp"/>
                    <TextView android:text="Risparmi" android:textColor="@color/text_secondary"
                        android:textSize="11sp" android:layout_marginEnd="16dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <View android:layout_width="12dp" android:layout_height="12dp"
                        android:background="#FF4081" android:layout_marginEnd="4dp"/>
                    <TextView android:text="Debiti" android:textColor="@color/text_secondary"
                        android:textSize="11sp" android:layout_marginEnd="16dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <View android:layout_width="12dp" android:layout_height="12dp"
                        android:background="#FFD600" android:layout_marginEnd="4dp"/>
                    <TextView android:text="Patrimonio netto" android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- SEZIONE: UTILIZZO RISPARMI (prelievi dagli obiettivi)       -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView android:id="@+id/cardWithdrawals"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp" android:layout_marginBottom="8dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="14dp" app:cardElevation="3dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <!-- Header -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="💸 Utilizzo Risparmi"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvTotalePrelievi"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0 €"
                        android:textColor="@color/color_expense"
                        android:textSize="18sp" android:textStyle="bold"/>
                </LinearLayout>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Importi prelevati dagli obiettivi di risparmio e utilizzati durante l'anno."
                    android:textColor="@color/text_secondary" android:textSize="12sp"
                    android:layout_marginBottom="12dp"/>

                <!-- Lista per obiettivo -->
                <LinearLayout android:id="@+id/containerPrelievi"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:layout_marginBottom="12dp"/>

                <!-- Donut prelievi per obiettivo -->
                <com.github.mikephil.charting.charts.PieChart android:id="@+id/pieChartPrelievi"
                    android:layout_width="match_parent" android:layout_height="180dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
