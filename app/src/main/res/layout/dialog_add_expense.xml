<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:padding="16dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Descrizione" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp"
            android:gravity="center_vertical">
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilCategory"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:hint="Categoria">
                <AutoCompleteTextView android:id="@+id/spinnerCategory"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="none" android:focusable="false"/>
            </com.google.android.material.textfield.TextInputLayout>
            <ImageButton android:id="@+id/btnManageCategories"
                android:layout_width="48dp" android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:src="@android:drawable/ic_menu_edit"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#7A90BB"
                android:contentDescription="Gestisci categorie"/>
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Importo (€)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAmount"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="numberDecimal"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Data (yyyy-MM-dd)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDate"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:focusable="false" android:clickable="true"/>
        </com.google.android.material.textfield.TextInputLayout>

        <CheckBox android:id="@+id/cbSubscription" android:text="Abbonamento"
            android:textColor="#CCCCCC"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <CheckBox android:id="@+id/cbNeed" android:text="Necessità (Need)"
            android:textColor="#CCCCCC"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Note (opzionale)" android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNotes"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Separatore -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A3A5A" android:layout_marginBottom="12dp"/>

        <!-- Bottone imposta ricorrente -->
        <Button android:id="@+id/btnSetRecurring"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="🔁  Imposta come spesa ricorrente"
            android:textColor="@color/color_expense"
            android:backgroundTint="#15FF4081"
            android:strokeColor="@color/color_expense"
            style="@style/Widget.Material3.Button.OutlinedButton"/>

        <!-- Badge visibile quando la ricorrenza è già impostata -->
        <TextView android:id="@+id/tvRecurringBadge"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:textColor="@color/color_expense"
            android:textSize="12sp"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>
