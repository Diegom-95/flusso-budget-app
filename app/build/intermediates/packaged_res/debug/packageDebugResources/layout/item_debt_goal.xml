<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp" android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="16dp" app:cardElevation="4dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <!-- Nome + bottoni azione -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:id="@+id/tvDebtName"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Debito" android:textColor="@color/text_primary"
                android:textSize="17sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvDebtStatus"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0%" android:textColor="@color/color_debt"
                android:textSize="18sp" android:textStyle="bold" android:layout_marginEnd="8dp"/>
            <ImageButton android:id="@+id/btnEditDebt"
                android:layout_width="32dp" android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_edit"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/text_secondary"/>
            <ImageButton android:id="@+id/btnDeleteDebt"
                android:layout_width="32dp" android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/color_expense"/>
        </LinearLayout>

        <!-- Progress bar -->
        <ProgressBar android:id="@+id/progressDebt"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent" android:layout_height="8dp"
            android:layout_marginVertical="10dp"
            android:progressTint="@color/color_debt"
            android:progressBackgroundTint="@color/divider"
            android:max="100" android:progress="0"/>

        <!-- Info debito (2 colonne) -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/tvDebtTotal" android:text="Totale: 0 €"
                    android:textColor="@color/text_label" android:textSize="12sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvDebtPaid" android:text="Pagato: 0 €"
                    android:textColor="@color/color_income" android:textSize="12sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvDebtRemaining" android:text="Rimanente: 0 €"
                    android:textColor="@color/color_expense" android:textSize="12sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="end">
                <TextView android:id="@+id/tvDebtMonthly" android:text="Rata: 0 €/mese"
                    android:textColor="@color/color_saving" android:textSize="12sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvMonthsLeft" android:text="— rate"
                    android:textColor="@color/text_secondary" android:textSize="12sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Bottone paga rata -->
        <Button android:id="@+id/btnPay"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:text="💳 Registra Pagamento"
            android:textColor="@color/bg_primary"
            android:backgroundTint="@color/color_debt"
            android:textSize="13sp"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
