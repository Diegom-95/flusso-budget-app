<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center"
    android:background="@color/bg_primary" android:padding="32dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🔒 Flusso" android:textColor="@color/text_primary"
        android:textSize="32sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Inserisci il tuo PIN per accedere"
        android:textColor="@color/text_secondary" android:textSize="14sp"
        android:layout_marginBottom="32dp"/>

    <LinearLayout android:id="@+id/layoutPin"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="center"
        android:visibility="gone">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="220dp" android:layout_height="wrap_content"
            android:hint="PIN" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPin"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="numberPassword" android:maxLength="6"
                android:gravity="center" android:textSize="24sp" android:letterSpacing="0.3"/>
        </com.google.android.material.textfield.TextInputLayout>

        <TextView android:id="@+id/tvPinError"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="PIN errato. Riprova." android:textColor="#FF4081"
            android:textSize="13sp" android:layout_marginBottom="12dp"
            android:visibility="gone"/>

        <Button android:id="@+id/btnPinOk"
            android:layout_width="220dp" android:layout_height="wrap_content"
            android:text="Sblocca" android:backgroundTint="@color/color_income"/>
    </LinearLayout>
</LinearLayout>
